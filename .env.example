# 新前端连接网关时使用的密码。请生成一段足够长的随机字符串。
GATEWAY_API_KEY=replace-with-a-long-random-secret

# Claude 或其他 OpenAI 兼容上游。不要把真实 Key 提交到 GitHub。
UPSTREAM_API_KEY=replace-with-your-upstream-key
UPSTREAM_BASE_URL=https://your-provider.example/v1
UPSTREAM_MODEL=your-claude-model-name

# 新前端模型列表里显示的名称，可以随意起名。
PUBLIC_MODEL_NAME=shanshan-claude

REQUEST_TIMEOUT_SECONDS=300
MAX_REQUEST_BYTES=10485760
