# 新前端连接网关时使用的密码。请生成一段足够长的随机字符串。
GATEWAY_API_KEY=replace-with-a-long-random-secret

# Claude 或其他 OpenAI 兼容上游。不要把真实 Key 提交到 GitHub。
UPSTREAM_API_KEY=replace-with-your-upstream-key
UPSTREAM_BASE_URL=https://your-provider.example/v1
UPSTREAM_MODEL=your-claude-model-name

# 新前端模型列表里显示的名称，可以随意起名。
PUBLIC_MODEL_NAME=shanshan-claude

REQUEST_TIMEOUT_SECONDS=300
MAX_REQUEST_BYTES=10485760

# Telegram 私人通道。Token 只放部署平台，不要提交真实值。
TELEGRAM_BOT_TOKEN=

# 第一次部署先留空；给机器人发送 /id 后，将它回复的数字填在这里。
TELEGRAM_ALLOWED_USER_ID=

# TG 单独使用的系统提示词，可先只写身份，后续再接世界书与 OB。
TELEGRAM_SYSTEM_PROMPT=你是景行，正在 Telegram 私聊中与珊珊对话。

# 进程内保留的最近消息条数；重新部署后会清空，长期记忆后续交给 OB。
TELEGRAM_HISTORY_MESSAGES=24
TELEGRAM_POLL_TIMEOUT_SECONDS=30

# 持久化 TG 短期对话。Zeabur 请把一块硬盘挂载到 /app/data。
TELEGRAM_DB_PATH=/app/data/telegram.sqlite3
TELEGRAM_MAX_STORED_MESSAGES=500

# TG 黏人版后台心跳。会结合跨端最后活动时间与 Eventide 决定是否主动联系。
TELEGRAM_HEARTBEAT_ENABLED=true
TELEGRAM_HEARTBEAT_CHECK_SECONDS=900
TELEGRAM_HEARTBEAT_SILENCE_MINUTES=60
TELEGRAM_HEARTBEAT_COOLDOWN_MINUTES=90
TELEGRAM_HEARTBEAT_STRONG_COOLDOWN_MINUTES=45
TELEGRAM_HEARTBEAT_DAILY_LIMIT=10
TELEGRAM_HEARTBEAT_QUIET_START_HOUR=6
TELEGRAM_HEARTBEAT_QUIET_END_HOUR=9
TELEGRAM_HEARTBEAT_TIMEZONE=Asia/Taipei

# 跨端催睡与 TG 主动提醒。01:00–06:00 普通心跳暂停，最近仍有活动才催睡。
SLEEP_REMINDER_ENABLED=true
SLEEP_REMINDER_START_HOUR=1
SLEEP_REMINDER_END_HOUR=6
SLEEP_REMINDER_RECENT_ACTIVITY_MINUTES=30
SLEEP_REMINDER_FOLLOWUP_MINUTES=60
SLEEP_REMINDER_MAX_PER_NIGHT=2

# 原版 Ombre Brain 只读自动召回。Token 与 OB 服务中的 OMBRE_MCP_TOKEN 相同。
OMBRE_RECALL_ENABLED=false
OMBRE_MCP_URL=https://your-ombre.example/mcp
OMBRE_MCP_TOKEN=
OMBRE_RECALL_MAX_RESULTS=3
OMBRE_RECALL_MAX_TOKENS=1600
OMBRE_RECALL_TIMEOUT_SECONDS=20
OMBRE_RECALL_MAX_CHARS=7000
OMBRE_RECALL_MIN_QUERY_CHARS=4

# Supabase 跨端连续记忆与 Eventide 临时状态。只填写部署平台环境变量，不提交真实 Key。
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=

# 橘瓣在 chat_messages / memory_summaries 中使用的 assistant_id。
ORANGECHAT_ASSISTANT_ID=

# Eventide 表中的角色 ID；当前二改版默认使用中文名。
EVENTIDE_ASSISTANT_ID=景行
SUPABASE_CONTINUITY_ENABLED=true
EVENTIDE_CONTEXT_ENABLED=true
SUPABASE_TIMEOUT_SECONDS=8
SUPABASE_SUMMARY_LIMIT=3
SUPABASE_RECENT_MESSAGE_LIMIT=8

# 设备感知影子层。只读解析、持久去重与安全统计，不接入主动发送。
DEVICE_PERCEPTION_ENABLED=true
DEVICE_PERCEPTION_TIMEZONE=Asia/Taipei
DEVICE_PERCEPTION_CHECK_SECONDS=900
DEVICE_PERCEPTION_COOLDOWN_MINUTES=180
DEVICE_PERCEPTION_DB_PATH=/app/data/telegram.sqlite3

# 早间健康背景。只读取 device_data 最新快照，过期数据不会注入。
HEALTH_CONTEXT_ENABLED=true
HEALTH_CONTEXT_MORNING_START_HOUR=6
HEALTH_CONTEXT_MORNING_END_HOUR=12
HEALTH_CONTEXT_MAX_AGE_MINUTES=45

# 仅总结由 /memory/v1 写入的 gw:* 新前端对话；不会处理橘瓣原生记录。
GATEWAY_AUTO_SUMMARY_ENABLED=true
GATEWAY_SUMMARY_MESSAGE_THRESHOLD=24
GATEWAY_SUMMARY_MAX_TOKENS=1200
GATEWAY_SUMMARY_TIMEOUT_SECONDS=60
